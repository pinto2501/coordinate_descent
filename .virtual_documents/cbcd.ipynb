import numpy as np
import matplotlib.pyplot as plt
import random





n = 100
c = 0.35

I = np.identity(n)
L = -np.tril(c * np.ones((n, n)), k=-1) # moves boundary one step below the diagonal
A_c = np.identity(n)- L - L.T
C = np.linalg.inv(I-L) @ L.T
S = np.diag([1/(n) for i in range(n)])
R = np.linalg.matrix_power(I - S @ np.linalg.inv(I) @ A_c, n) 


epochs = 10000
x0 = np.ones((n,1))
x = x0.copy()
x_star = np.zeros((n,1))
ccd_errors = []

for l in range(epochs):
    x = C @ x
    ratio = np.linalg.norm(x - x_star) / np.linalg.norm(x0 - x_star)
    ccd_errors.append(np.log(ratio))

ccd_slope, intercept = np.polyfit(range(epochs), ccd_errors, 1)
rho_ccd = np.max(np.abs(np.linalg.eigvals(C)))
rate_ccd = -np.log(rho_ccd)
print(-ccd_slope, rate_ccd)
plt.plot(ccd_errors)
plt.title(f"CCD (n={n}, c={c})")


epochs = 10000
x0 = np.ones((n,1))
x = x0.copy()
x_star = np.zeros((n,1))
rcd_errors = []

for l in range(epochs):
    x = R @ x
    norm = np.linalg.norm(x - x_star)
    if norm < 1e-50:
        print(f"Converges at epoch {l}")
        break
    ratio = norm / np.linalg.norm(x0 - x_star)
    rcd_errors.append(np.log(ratio))


ercd_slope, intercept = np.polyfit(range(len(rcd_errors)), rcd_errors, 1)
rho_ercd = np.max(np.abs(np.linalg.eigvals(R)))
rate_ercd = -np.log(rho_ercd)
print(-ercd_slope, rate_ercd)
plt.plot(rcd_errors)
plt.title(f"ERCD (n={n}, c={c})")


def build_coordinate_matrices(n, c):
    mats = []
    for i in range(n):
        M = np.eye(n)
        M[i, i] = 0.0
        M[i, :] = -c  
        M[i, i] = 0.0  
        mats.append(M)
    return mats

mats = build_coordinate_matrices(n, c)

# check if mats is correct

for mat in mats:
    mul_mat = np.matmul(mat, mat)
    if np.array_equal(mat @ mat, mat):
        pass
    else:
        print("Error")


epochs = 10000
x0 = np.ones((n, 1))
x = x0.copy()
x_star = np.zeros((n, 1))
prcd_errors = []

for l in range(epochs):
    i = random.randint(0, n - 1)
    x = mats[i] @ x
    ratio = np.linalg.norm(x - x_star) / np.linalg.norm(x0 - x_star)
    prcd_errors.append(np.log(ratio))


prcd_slope, intercept = np.polyfit(range(epochs), prcd_errors, 1)
print(-prcd_slope)
plt.plot(prcd_errors)
plt.title(f"PRCD (n={n}, c={c})")
plt.xlabel("Epoch")
plt.ylabel("Log ratio")


print(-prcd_slope, -ccd_slope, -ercd_slope)
